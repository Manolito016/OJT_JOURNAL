# OJT AI Journal Report Generator - Git Ignore File
# Production-ready structure

# =============================================================================
# ENVIRONMENT & SECURITY
# =============================================================================
# Environment files (contains sensitive API keys)
.env
.env.local
.env.*.local
!.env.example

# =============================================================================
# DATABASE
# =============================================================================
# SQLite database (keep schema, ignore data)
db/*.db
db/*.db-journal
db/*.db-shm
db/*.db-wal

# =============================================================================
# LOGS
# =============================================================================
# Log files
logs/*.log
logs/*.txt
!logs/.gitkeep

# =============================================================================
# UPLOADS
# =============================================================================
# User uploads (keep directory, ignore files)
public/uploads/*
!public/uploads/.gitkeep

# =============================================================================
# IDE & EDITORS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# =============================================================================
# OPERATING SYSTEM
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# TEMPORARY FILES
# =============================================================================
tmp/
temp/
*.tmp
*.cache

# =============================================================================
# BUILD OUTPUTS
# =============================================================================
dist/
build/

# =============================================================================
# DEPENDENCIES
# =============================================================================
vendor/
node_modules/
package-lock.json
yarn.lock
composer.lock

# =============================================================================
# TEST FILES (Optional - uncomment if needed)
# =============================================================================
# tests/coverage/
# .phpunit.result.cache
